<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lumière Du Progrès</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 20px; }
    h1 { text-align: center; }
    table { width: 100%; border-collapse: collapse; margin-top: 20px; }
    th, td { border: 1px solid #333; padding: 8px; text-align: left; }
    th { background-color: #eee; }
    input { margin: 5px; }
    button { margin: 5px; padding: 5px 10px; }
  </style>
</head>
<body>
  <h1>Lumière Du Progrès</h1>

  <section id="create-user">
    <h2>Create User</h2>
    <input type="text" id="username" placeholder="Username">
    <button onclick="createUser()">Create User</button>
  </section>

  <section id="transaction">
    <h2>Deposit / Withdraw</h2>
    <input type="text" id="tx-username" placeholder="Username">
    <input type="number" id="amount" placeholder="Amount">
    <button onclick="deposit()">Deposit</button>
    <button onclick="withdraw()">Withdraw</button>
  </section>

  <section id="users">
    <h2>Users</h2>
    <table id="users-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Username</th>
          <th>Balance</th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
  </section>

  <script>
    const API_URL = "https://ldp-backend-ltrm.onrender.com";

    async function fetchUsers() {
      const res = await fetch(`${API_URL}/users`);
      const data = await res.json();
      const tbody = document.querySelector("#users-table tbody");
      tbody.innerHTML = "";
      data.forEach(user => {
        const row = `<tr>
          <td>${user.id}</td>
          <td>${user.username}</td>
          <td>${user.balance}</td>
        </tr>`;
        tbody.innerHTML += row;
      });
    }

    async function createUser() {
      const username = document.getElementById("username").value;
      if(!username) return alert("Enter a username");
      await fetch(`${API_URL}/create-user`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ username })
      });
      document.getElementById("username").value = "";
      fetchUsers();
    }

    async function deposit() {
      const username = document.getElementById("tx-username").value;
      const amount = Number(document.getElementById("amount").value);
      if(!username || !amount) return alert("Enter username and amount");
      await fetch(`${API_URL}/deposit`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ username, amount })
      });
      document.getElementById("amount").value = "";
      fetchUsers();
    }

    async function withdraw() {
      const username = document.getElementById("tx-username").value;
      const amount = Number(document.getElementById("amount").value);
      if(!username || !amount) return alert("Enter username and amount");
      await fetch(`${API_URL}/withdraw`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ username, amount })
      });
      document.getElementById("amount").value = "";
      fetchUsers();
    }

    // Load users on page load
    fetchUsers();
  </script>
</body>
</html>
